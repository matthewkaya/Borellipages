---
import AdminLayout from "@/layouts/AdminLayout.astro";
---

<AdminLayout title="Admin Login | Borrelli Crafters">
  <section class="mx-auto max-w-md space-y-6 rounded-2xl border border-ink/10 bg-white p-8 shadow-soft">
    <h1 class="text-3xl font-semibold text-ink">Designer Login</h1>
    <p class="text-sm text-slate">
      Default credentials:
      <span class="font-semibold text-ink">admin / pass</span>
    </p>

    <form id="admin-login-form" class="space-y-4" novalidate>
      <div>
        <label for="username" class="mb-1 block text-sm font-medium text-ink">Username</label>
        <input id="username" name="username" type="text" class="field" autocomplete="username" required />
      </div>
      <div>
        <label for="password" class="mb-1 block text-sm font-medium text-ink">Password</label>
        <input id="password" name="password" type="password" class="field" autocomplete="current-password" required />
      </div>
      <p id="admin-login-error" class="error-text" aria-live="polite"></p>
      <button type="submit" class="btn-primary w-full">Log in</button>
    </form>
  </section>

  <script>
    import { initAdminLogin } from "@/scripts/adminLogin";

    initAdminLogin();
  </script>
</AdminLayout>
