---
import AdminLayout from "@/layouts/AdminLayout.astro";
---

<AdminLayout title="Admin Settings | Borrelli Crafters">
  <section class="mx-auto max-w-4xl space-y-6 rounded-2xl border border-ink/10 bg-white p-8 shadow-soft">
    <div class="flex flex-wrap items-center justify-between gap-3">
      <h1 class="text-3xl font-semibold text-ink">Admin Settings</h1>
      <div class="flex gap-2">
        <a href="/admin/" class="btn-secondary">Back to Designer</a>
        <button id="admin-logout" type="button" class="btn-secondary">Logout</button>
      </div>
    </div>

    <p class="text-sm text-slate">
      Changes here are saved in this browser only. Use Designer export/import to move settings between browsers or publish them.
    </p>

    <section class="space-y-4 rounded-xl border border-ink/10 bg-slate-50 p-5">
      <h2 class="text-xl font-semibold text-ink">Business Information</h2>
      <form id="admin-business-form" class="space-y-4" novalidate>
        <div class="grid gap-4 md:grid-cols-2">
          <div>
            <label for="brand-name" class="mb-1 block text-sm font-medium text-ink">Business Name</label>
            <input id="brand-name" type="text" class="field" />
          </div>
          <div>
            <label for="brand-tagline" class="mb-1 block text-sm font-medium text-ink">Tagline</label>
            <input id="brand-tagline" type="text" class="field" />
          </div>
        </div>

        <div class="grid gap-4 md:grid-cols-2">
          <div>
            <label for="brand-phone" class="mb-1 block text-sm font-medium text-ink">Phone</label>
            <input id="brand-phone" type="tel" inputmode="tel" class="field" />
          </div>
          <div>
            <label for="brand-email" class="mb-1 block text-sm font-medium text-ink">Email</label>
            <input id="brand-email" type="email" inputmode="email" class="field" />
          </div>
        </div>

        <div>
          <label for="brand-address" class="mb-1 block text-sm font-medium text-ink">Address</label>
          <input id="brand-address" type="text" class="field" />
        </div>

        <div>
          <label for="brand-service-area" class="mb-1 block text-sm font-medium text-ink">Service Area</label>
          <input id="brand-service-area" type="text" class="field" />
        </div>

        <div class="grid gap-4 md:grid-cols-3">
          <div>
            <label for="brand-instagram" class="mb-1 block text-sm font-medium text-ink">Instagram URL</label>
            <input id="brand-instagram" type="url" inputmode="url" class="field" />
          </div>
          <div>
            <label for="brand-facebook" class="mb-1 block text-sm font-medium text-ink">Facebook URL</label>
            <input id="brand-facebook" type="url" inputmode="url" class="field" />
          </div>
          <div>
            <label for="brand-linkedin" class="mb-1 block text-sm font-medium text-ink">LinkedIn URL</label>
            <input id="brand-linkedin" type="url" inputmode="url" class="field" />
          </div>
        </div>

        <p id="business-feedback" class="rounded-lg bg-slate-100 px-3 py-2 text-sm text-slate-700" aria-live="polite">
          Ready.
        </p>

        <button type="submit" class="btn-primary">Save Business Info</button>
      </form>
    </section>

    <section class="space-y-4 rounded-xl border border-ink/10 bg-slate-50 p-5">
      <h2 class="text-xl font-semibold text-ink">Logo Upload</h2>
      <p class="text-sm text-slate">
        Upload a logo file. It is stored in your browser as part of runtime config.
      </p>

      <form id="admin-logo-form" class="space-y-4" novalidate>
        <div>
          <label for="logo-upload" class="mb-1 block text-sm font-medium text-ink">Logo File</label>
          <input
            id="logo-upload"
            type="file"
            accept=".png,.jpg,.jpeg,.webp,.avif,.svg,image/*"
            class="field"
          />
        </div>

        <div>
          <label for="logo-alt" class="mb-1 block text-sm font-medium text-ink">Logo Alt Text</label>
          <input id="logo-alt" type="text" class="field" placeholder="Borrelli Crafters logo" />
        </div>

        <div>
          <p class="mb-1 text-sm font-medium text-ink">Preview</p>
          <div id="logo-preview" class="rounded-lg border border-ink/10 bg-white p-3"></div>
        </div>

        <p id="logo-feedback" class="rounded-lg bg-slate-100 px-3 py-2 text-sm text-slate-700" aria-live="polite">
          Ready.
        </p>

        <div class="flex flex-wrap gap-2">
          <button type="submit" class="btn-primary">Save Logo</button>
          <button id="logo-clear" type="button" class="btn-secondary">Clear Logo</button>
        </div>
      </form>
    </section>

    <section class="space-y-4 rounded-xl border border-ink/10 bg-slate-50 p-5">
      <h2 class="text-xl font-semibold text-ink">Landing Hero Video Upload</h2>
      <p class="text-sm text-slate">
        Upload an MP4 or WebM video for the homepage hero. If cleared, the site falls back to auto-discovered hero media.
      </p>

      <form id="admin-landing-media-form" class="space-y-4" novalidate>
        <div>
          <label for="landing-video-upload" class="mb-1 block text-sm font-medium text-ink">Hero Video File</label>
          <input id="landing-video-upload" type="file" accept=".mp4,.webm,video/mp4,video/webm" class="field" />
        </div>

        <div>
          <p class="mb-1 text-sm font-medium text-ink">Preview</p>
          <div id="landing-media-preview" class="rounded-lg border border-ink/10 bg-white p-3"></div>
        </div>

        <p
          id="landing-media-feedback"
          class="rounded-lg bg-slate-100 px-3 py-2 text-sm text-slate-700"
          aria-live="polite"
        >
          Ready.
        </p>

        <div class="flex flex-wrap gap-2">
          <button type="submit" class="btn-primary">Save Hero Video</button>
          <button id="landing-video-clear" type="button" class="btn-secondary">Clear Hero Video</button>
        </div>
      </form>
    </section>

    <section class="space-y-4 rounded-xl border border-ink/10 bg-slate-50 p-5">
      <h2 class="text-xl font-semibold text-ink">Password</h2>
      <p class="text-sm text-slate">Change the Designer password hash stored in localStorage.</p>

      <form id="admin-password-form" class="space-y-4" novalidate>
        <div>
          <label for="old-password" class="mb-1 block text-sm font-medium text-ink">Current Password</label>
          <input id="old-password" type="password" class="field" autocomplete="current-password" required />
        </div>

        <div>
          <label for="new-password" class="mb-1 block text-sm font-medium text-ink">New Password</label>
          <input id="new-password" type="password" class="field" autocomplete="new-password" required />
        </div>

        <div>
          <label for="confirm-password" class="mb-1 block text-sm font-medium text-ink">Confirm New Password</label>
          <input id="confirm-password" type="password" class="field" autocomplete="new-password" required />
        </div>

        <p
          id="password-feedback"
          class="rounded-lg bg-slate-100 px-3 py-2 text-sm text-slate-700"
          aria-live="polite"
        >
          Ready.
        </p>

        <button type="submit" class="btn-primary">Update Password</button>
      </form>
    </section>
  </section>

  <script>
    import { initAdminSettings } from "@/scripts/adminSettings";

    initAdminSettings();
  </script>
</AdminLayout>
