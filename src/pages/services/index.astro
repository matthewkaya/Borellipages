---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getDefaultConfig } from "@/lib/config";

const config = getDefaultConfig();
const withTrailingSlash = (value: string) =>
  value.endsWith("/") ? value : `${value}/`;
---

<BaseLayout
  title="Services | Borrelli Crafters"
  description="Explore custom home builds, renovations, and sustainable craftsmanship services."
  config={config}
  currentPath="/services/"
>
  <section class="section-shell py-14 md:py-16">
    <h1 class="text-4xl font-semibold text-ink md:text-5xl">Services</h1>
    <p class="mt-4 max-w-3xl text-base leading-relaxed text-slate md:text-lg">
      Explore our service paths, compare fit, and move directly to the scope
      details that match your project goals.
    </p>

    <div class="mt-10 grid gap-5 md:grid-cols-3">
      {
        config.home.services.map((service) => (
          <article class="surface-card rounded-2xl p-6">
            <h2 class="text-xl font-semibold text-ink">{service.title}</h2>
            <p class="mt-3 text-sm leading-relaxed text-slate">{service.blurb}</p>
            <a
              href={withTrailingSlash(service.href)}
              class="mt-5 inline-flex text-sm font-semibold text-brand underline underline-offset-4"
            >
              View details
            </a>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section-shell pb-16">
    <div class="surface-card rounded-2xl p-8 md:flex md:items-center md:justify-between md:gap-8">
      <div>
        <h2 class="text-3xl font-semibold text-ink">Need Help Choosing the Right Path?</h2>
        <p class="mt-2 max-w-2xl text-sm leading-relaxed text-slate">
          Book a consultation and we will map your scope, timeline, and best-fit service.
        </p>
      </div>
      <a href="/book/" class="btn-primary mt-6 md:mt-0">Book a Consultation</a>
    </div>
  </section>
</BaseLayout>
