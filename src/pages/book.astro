---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getDefaultConfig } from "@/lib/config";

const config = getDefaultConfig();
---

<BaseLayout
  title="Book a Consultation | Borrelli Crafters"
  description="Book a consultation for your custom home, renovation, or sustainable craftsmanship project."
  config={config}
  currentPath="/book"
>
  <section class="section-shell py-14">
    <div class="grid gap-8 lg:grid-cols-[1.1fr_0.9fr]">
      <div>
        <h1 id="contact-headline" class="text-4xl font-semibold text-ink md:text-5xl">
          {config.contactPage.headline}
        </h1>
        <p id="contact-intro" class="mt-4 max-w-2xl text-base leading-relaxed text-slate md:text-lg">
          {config.contactPage.intro}
        </p>

        <div class="mt-6 rounded-xl border border-ink/10 bg-white p-5">
          <h2 class="text-lg font-semibold text-ink">Direct Contact</h2>
          <ul class="mt-3 space-y-2 text-sm text-slate">
            <li>
              <span class="font-semibold text-ink">Phone:</span>
              <a
                id="contact-direct-phone"
                href={`tel:${config.brand.phone}`}
                class="ml-1 underline underline-offset-2"
              >
                {config.brand.phone}
              </a>
            </li>
            <li>
              <span class="font-semibold text-ink">Email:</span>
              <a
                id="contact-direct-email"
                href={`mailto:${config.brand.email}`}
                class="ml-1 underline underline-offset-2"
              >
                {config.brand.email}
              </a>
            </li>
            <li>
              <span class="font-semibold text-ink">Service Area:</span>
              <span id="contact-direct-service-area" class="ml-1">{config.brand.serviceArea}</span>
            </li>
            <li>
              <span class="font-semibold text-ink">Address:</span>
              <span id="contact-direct-address" class="ml-1">{config.brand.address}</span>
            </li>
          </ul>
        </div>
      </div>

      <div id="contact-form" class="surface-card rounded-2xl p-6">
        <p id="contact-success" class="hidden rounded-xl bg-emerald-50 px-4 py-3 text-sm text-emerald-700"></p>

        <form
          id="consultation-form"
          name="consultation"
          method="POST"
          action="/book?success=1#contact-form"
          data-netlify="true"
          netlify-honeypot="bot-field"
          novalidate
          class="space-y-4"
        >
          <input type="hidden" name="form-name" value="consultation" />
          <p class="hidden">
            <label>
              Don&apos;t fill this out if you&apos;re human:
              <input name="bot-field" />
            </label>
          </p>

          <div>
            <label for="full-name" class="mb-1 block text-sm font-medium text-ink">Full Name</label>
            <input
              id="full-name"
              name="full-name"
              type="text"
              autocomplete="name"
              required
              aria-describedby="full-name-error"
              class="field"
            />
            <p id="full-name-error" class="error-text" aria-live="polite"></p>
          </div>

          <div>
            <label for="email" class="mb-1 block text-sm font-medium text-ink">Email</label>
            <input
              id="email"
              name="email"
              type="email"
              inputmode="email"
              autocomplete="email"
              required
              aria-describedby="email-error"
              class="field"
            />
            <p id="email-error" class="error-text" aria-live="polite"></p>
          </div>

          <div>
            <label for="phone" class="mb-1 block text-sm font-medium text-ink">Phone</label>
            <input
              id="phone"
              name="phone"
              type="tel"
              inputmode="tel"
              autocomplete="tel"
              required
              aria-describedby="phone-error"
              class="field"
            />
            <p id="phone-error" class="error-text" aria-live="polite"></p>
          </div>

          <div>
            <label for="service" class="mb-1 block text-sm font-medium text-ink">Project Type</label>
            <select id="service" name="service" required aria-describedby="service-error">
              <option value="">Select a project type</option>
              <option value="custom-home-builds">Custom Home Builds</option>
              <option value="renovations-expansions">Renovations & Expansions</option>
              <option value="sustainable-craftsmanship">Sustainable Craftsmanship</option>
            </select>
            <p id="service-error" class="error-text" aria-live="polite"></p>
          </div>

          <div>
            <label for="timeline" class="mb-1 block text-sm font-medium text-ink">Preferred Start Timeline</label>
            <input
              id="timeline"
              name="timeline"
              type="month"
              aria-describedby="timeline-error"
              class="field"
            />
            <p id="timeline-error" class="error-text" aria-live="polite"></p>
          </div>

          <div>
            <label for="project-details" class="mb-1 block text-sm font-medium text-ink">Project Details</label>
            <textarea
              id="project-details"
              name="project-details"
              rows="5"
              required
              aria-describedby="project-details-error"
            ></textarea>
            <p id="project-details-error" class="error-text" aria-live="polite"></p>
          </div>

          <p id="contact-privacy" class="text-xs leading-relaxed text-slate">{config.contactPage.privacyNote}</p>

          <button type="submit" class="btn-primary w-full">Send Consultation Request</button>
        </form>
      </div>
    </div>
  </section>

  <script>
    import { initContactPage } from "@/scripts/siteRuntime";
    import { initContactFormValidation } from "@/scripts/contactForm";

    initContactPage();
    initContactFormValidation();
  </script>
</BaseLayout>
