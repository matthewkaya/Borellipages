---
import type { BeforeAfterPair } from "@/lib/mediaSelect";
import { resolveAlt } from "@/lib/mediaSelect";

interface Props {
  pairs: BeforeAfterPair[];
  altOverrides: Record<string, string>;
}

const { pairs, altOverrides } = Astro.props as Props;
---

<section aria-labelledby="before-after-heading" class="space-y-5">
  <h2 id="before-after-heading" class="text-2xl font-semibold text-ink">Before / After Highlights</h2>

  {
    pairs.length === 0 ? (
      <p class="rounded-xl border border-dashed border-ink/20 bg-white px-4 py-6 text-sm text-slate">
        Add paired files in <code>src/assets/media/renovations-additions/before-after-pairs/</code>
        using <code>project_before.jpg</code> and <code>project_after.jpg</code>.
      </p>
    ) : (
      <div class="grid gap-6 lg:grid-cols-2">
        {pairs.map((pair, index) => (
          <article class="space-y-3" data-before-after>
            <p class="text-sm font-semibold text-slate">Project {index + 1}</p>
            <div class="before-after" data-before-after-root>
              <img
                class="before-after__base"
                src={pair.before.src}
                width={pair.before.width}
                height={pair.before.height}
                loading="lazy"
                decoding="async"
                alt={resolveAlt(pair.before, altOverrides)}
              />
              <div class="before-after__overlay-wrap" data-after-wrap>
                <img
                  class="before-after__overlay"
                  src={pair.after.src}
                  width={pair.after.width}
                  height={pair.after.height}
                  loading="lazy"
                  decoding="async"
                  alt={resolveAlt(pair.after, altOverrides)}
                />
              </div>
              <button
                type="button"
                class="before-after__handle"
                data-before-after-handle
                role="slider"
                aria-label="Adjust before and after split"
                aria-valuemin="0"
                aria-valuemax="100"
                aria-valuenow="50"
              ></button>
            </div>

            <noscript>
              <div class="grid gap-2">
                <img src={pair.before.src} alt={resolveAlt(pair.before, altOverrides)} />
                <img src={pair.after.src} alt={resolveAlt(pair.after, altOverrides)} />
              </div>
            </noscript>
          </article>
        ))}
      </div>
    )
  }
</section>

<script>
  const sliders = Array.from(document.querySelectorAll("[data-before-after-root]"));

  sliders.forEach((slider) => {
    const handle = slider.querySelector("[data-before-after-handle]");
    const afterWrap = slider.querySelector("[data-after-wrap]");

    if (!(handle instanceof HTMLButtonElement) || !(afterWrap instanceof HTMLElement)) {
      return;
    }

    let percent = 50;
    let isDragging = false;

    const update = (nextPercent) => {
      percent = Math.min(100, Math.max(0, nextPercent));
      afterWrap.style.width = `${percent}%`;
      handle.style.left = `calc(${percent}% - 1rem)`;
      handle.setAttribute("aria-valuenow", String(Math.round(percent)));
    };

    const updateFromX = (clientX) => {
      const rect = slider.getBoundingClientRect();
      const ratio = ((clientX - rect.left) / rect.width) * 100;
      update(ratio);
    };

    const stop = () => {
      isDragging = false;
      window.removeEventListener("pointermove", onMove);
      window.removeEventListener("pointerup", stop);
    };

    const onMove = (event) => {
      if (!isDragging) {
        return;
      }
      updateFromX(event.clientX);
    };

    handle.addEventListener("pointerdown", (event) => {
      isDragging = true;
      updateFromX(event.clientX);
      window.addEventListener("pointermove", onMove);
      window.addEventListener("pointerup", stop);
    });

    handle.addEventListener("keydown", (event) => {
      const step = 5;
      if (event.key === "ArrowLeft") {
        event.preventDefault();
        update(percent - step);
      }
      if (event.key === "ArrowRight") {
        event.preventDefault();
        update(percent + step);
      }
      if (event.key === "Home") {
        event.preventDefault();
        update(0);
      }
      if (event.key === "End") {
        event.preventDefault();
        update(100);
      }
    });

    update(percent);
  });
</script>
