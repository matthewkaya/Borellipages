---
interface Props {
  whoFor: string[];
  whoNotFor: string[];
}

const { whoFor, whoNotFor } = Astro.props as Props;
---

<section aria-labelledby="fit-heading" class="space-y-4">
  <h2 id="fit-heading" class="text-2xl font-semibold text-ink">Is This the Right Fit?</h2>
  <div class="grid gap-4 md:grid-cols-2">
    <article class="surface-card rounded-2xl p-5">
      <h3 class="text-lg font-semibold text-pine">Who It&apos;s For</h3>
      <ul class="mt-3 space-y-2 text-sm text-slate">
        {
          whoFor.map((item) => (
            <li class="flex gap-2"><span aria-hidden="true">•</span><span>{item}</span></li>
          ))
        }
      </ul>
    </article>

    <article class="surface-card rounded-2xl p-5">
      <h3 class="text-lg font-semibold text-brand">Who It&apos;s Not For</h3>
      <ul class="mt-3 space-y-2 text-sm text-slate">
        {
          whoNotFor.map((item) => (
            <li class="flex gap-2"><span aria-hidden="true">•</span><span>{item}</span></li>
          ))
        }
      </ul>
    </article>
  </div>
</section>
